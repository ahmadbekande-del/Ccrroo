<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Destroyer Mobile</title>
    <script src="https://unpkg.com/lightweight-charts/dist/lightweight-charts.standalone.production.js"></script>
    <style>
        body { font-family: sans-serif; background: #050a18; color: white; margin: 0; padding: 10px; }
        .card { background: #111827; border-radius: 15px; padding: 15px; margin-bottom: 15px; border: 1px solid #1f2937; }
        .header { display: flex; justify-content: space-between; align-items: center; padding: 10px; }
        .price { color: #3b82f6; font-weight: bold; font-size: 1.2em; }
        .chart-box { width: 100%; height: 120px; margin-top: 10px; pointer-events: none; }
        .badge { padding: 3px 8px; border-radius: 5px; font-size: 0.7em; font-weight: bold; }
        .hot { background: #ef4444; }
        .warm { background: #f59e0b; }
        .btn-scan { background: #3b82f6; color: white; border: none; padding: 12px; border-radius: 10px; width: 100%; font-weight: bold; margin-bottom: 20px; }
    </style>
</head>
<body>

    <div class="header">
        <h2>الملف المدمر V5 🚀</h2>
    </div>
    
    <button class="btn-scan" onclick="triggerScan()">إبدأ فحص السوق الآن ⚡</button>

    <div id="signals-list"></div>

    <script>
        async function loadSignals() {
            const res = await fetch('/api/signals?limit=10');
            const data = await res.json();
            const container = document.getElementById('signals-list');
            container.innerHTML = '';

            data.forEach((sig, i) => {
                const id = `chart-${i}`;
                container.innerHTML += `
                    <div class="card">
                        <div style="display:flex; justify-content:space-between">
                            <span><b>${sig.coin}/USDT</b> <span class="badge ${sig.type.toLowerCase()}">${sig.type}</span></span>
                            <span class="price">$${sig.price}</span>
                        </div>
                        <div id="${id}" class="chart-box"></div>
                        <div style="display:flex; justify-content:space-between; margin-top:10px; font-size:0.8em; color:#9ca3af">
                            <span>🎯 ${sig.target}</span>
                            <span>🛡️ ${sig.stop}</span>
                            <span style="color:#10b981">Score: ${sig.score}</span>
                        </div>
                    </div>
                `;
                // رسم البيانات الحقيقية القادمة من السيرفر
                setTimeout(() => renderChart(id, sig.history, sig.change24h >= 0 ? '#10b981' : '#ef4444'), 100);
            });
        }

        function renderChart(divId, history, color) {
            const chart = LightweightCharts.createChart(document.getElementById(divId), {
                layout: { background: { color: 'transparent' }, textColor: '#4b5563' },
                grid: { vertLines: { visible: false }, horzLines: { visible: false } },
                timeScale: { visible: false }, rightPriceScale: { visible: false },
                handleScroll: false, handleScale: false
            });
            const line = chart.addLineSeries({ color: color, lineWidth: 2 });
            line.setData(history);
        }

        async function triggerScan() {
            await fetch('/api/scan/now', {method: 'POST'});
            alert("بدأ الفحص.. سيتم التحديث تلقائياً");
            setTimeout(loadSignals, 5000);
        }

        loadSignals();
        setInterval(loadSignals, 60000); // تحديث كل دقيقة
    </script>
</body>
</html>
